# Retrofy Environment Configuration
# Copy this file to .env and update with your values

# Database configuration
DB_PATH=/srv/sqlite/ma_base.sqlite
IMAGES_DIR=./images

# Flask secret key (generate a secure random key)
SECRET_KEY=your-super-secret-key-change-this

# Admin authentication
# Run python generate_password.py to generate a secure password hash
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=your-bcrypt-hash-here

# Example of a generated hash (DO NOT USE THIS IN PRODUCTION):
# ADMIN_PASSWORD_HASH=$2b$12$LQv3c1yqBWVHxkd0LHAkCOYz6TtxMQJqhN8/LewdBPj4J/8KqKqKq
